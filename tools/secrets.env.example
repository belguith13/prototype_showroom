# Variables d'environnement — Prototype Bella Cucina
# À configurer dans le module Secrets de Paperclip
# NE JAMAIS committer ce fichier avec de vraies valeurs

# --- E-mail IMAP/SMTP ---
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=contact@bellacucina.fr
EMAIL_PASS=CHANGEME

# --- CRM Notion ---
NOTION_TOKEN=secret_CHANGEME
NOTION_CRM_DB_ID=CHANGEME

# --- Paperclip API (injecté automatiquement au runtime) ---
# PAPERCLIP_API_URL=http://localhost:3100/api
# PAPERCLIP_API_KEY=injecté par Paperclip via heartbeat JWT

# --- LLM (clé du client) ---
ANTHROPIC_API_KEY=CHANGEME
